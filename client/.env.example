# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin (Required for /admin panel access, comma separated)
NEXT_PUBLIC_ADMIN_EMAIL=admin1@gmail.com,admin2@gmail.com

# Site URL (Required for OAuth redirects in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google reCAPTCHA v3 (Optional, for bot protection)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-site-key
RECAPTCHA_SECRET_KEY=your-secret-key

# NextAuth Secret (If next-auth is added later for JWT)
NEXTAUTH_SECRET=your-secret
